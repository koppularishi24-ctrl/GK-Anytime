{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Public and private information about a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique Firebase Auth UID." },
        "displayName": { "type": "string", "description": "The user's preferred name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "Link to the user's avatar (optional)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["userId", "displayName", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Stores user profile information."
    }
  }
}
