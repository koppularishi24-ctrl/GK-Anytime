rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 1. Master Gate & Denial of Wallet
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Global Helpers
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // ---------------------------------------------------------
    // User Profile Validation
    // ---------------------------------------------------------
    function isValidUser(data) {
      return data.userId == request.auth.uid
        && data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 150
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      // 8. Secure List Queries: Only allow users to see their own profile
      allow get: if isOwner(userId);
      allow list: if false; // Profiles are private by default

      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().keys().hasAll(['userId', 'displayName', 'email', 'createdAt']);

      allow update: if isOwner(userId)
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Update Profile Info
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
        );

      allow delete: if false; // Profiles cannot be deleted from client
    }
  }
}
